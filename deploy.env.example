# 复制为 deploy.env 后填写（deploy.env 已在 .gitignore，勿提交密钥）
#
# 说明：scripts/deploy-aliyun.sh 为运维一键脚本；配置好 deploy.env 后执行 npm run deploy:aliyun
#
# 阿里云 SSH
DEPLOY_HOST=你的ECS公网IP
DEPLOY_USER=root
# 服务器上项目根目录（须与 PM2 工作目录、Nginx 反代一致）
DEPLOY_PATH=/home/app/universal-shop-v1.2.0
# 可选：私钥路径；留空则使用 ~/.ssh/config 中对应 Host 的配置
# DEPLOY_SSH_KEY=/Users/you/.ssh/your_key

# 部署完成后提示用（健康检查），可填公网域名
DEPLOY_PUBLIC_URL=https://your-shop.example.com

# ---------- 增量部署：是否跳过 npm install ----------
# true（默认）：非首次部署不执行 npm install，加快发布（仅替换代码 + 跑数据库升级 + PM2 重启）
# false：每次部署都 npm install --omit=dev（package.json / lock 变更时必须）
DEPLOY_UPGRADE_SKIP_NPM=true

# ---------- 首次 vs 增量（自动）----------
# 服务器在 DEPLOY_PATH 下若无文件 .deploy_initialized，则视为「首次部署」：
#   - 执行 npm install --omit=dev
#   - 执行 scripts/production-deploy-setup.mjs（建表、补丁、默认配置、行政区数据、默认管理员等，不重置已有管理员密码）
#   - PM2 启动/重启后写入 .deploy_initialized
# 若已存在 .deploy_initialized：增量部署（行为见 DEPLOY_UPGRADE_SKIP_NPM）
# 需强制重新走「首次」流程时：登录服务器删除 .deploy_initialized（勿误删 database）

# ---------- 数据库与 SQL 参考 ----------
# 运维可读：scripts/db/init/sqlite-init-reference.sql（补丁表说明 + 与 patches 对应关系）
# 实际建表与升级：NODE_ENV=production node scripts/production-deploy-setup.mjs（由 deploy-on-server.sh 调用，内含商品分类表与 category_id 幂等迁移）
# 若只需单独跑商品分类增量（与上重复执行也安全，幂等）：
#   npm run migrate:production:categories
#
# deploy 会：1) 备份 database/shop.sqlite → database/backups/shop.sqlite.predeploy.*
# 2) 不使用 sequelize.sync({ force: true })；增量 ALTER 放在 scripts/db/patches/（三位数字前缀 .sql）
#
# 若在 Mac 上打包：请使用仓库内 package.sh（已设 COPYFILE_DISABLE=1），勿手动 tar 带进 ._ 元数据文件，
# 否则 Linux 上可能把 ._010_*.sql 当补丁执行并报 SQLITE_MISUSE。服务器可删除 scripts/db/patches/._* 后重跑部署。
